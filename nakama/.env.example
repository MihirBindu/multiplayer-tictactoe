# Nakama + PostgreSQL — local secrets template
#
# Usage:
#   cp nakama/.env.example .env          (root .env — used by root docker-compose.yml)
#   cp nakama/.env.example nakama/.env   (nakama/.env — used by nakama/docker-compose.yml)
#
# .env and nakama/.env are gitignored and MUST NOT be committed.
# This file (.env.example) is safe to commit — it contains no real secrets.

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_DB=nakama
POSTGRES_USER=nakama
# Change POSTGRES_PASSWORD to a long random string in production.
POSTGRES_PASSWORD=localdb

# ── Nakama server key ──────────────────────────────────────────────────────────
# Used by:
#   - Nakama server  -> --socket.server_key  (root docker-compose.yml)
#   - Frontend build -> VITE_NK_KEY          (baked into the JS bundle at build time)
# Both values MUST match.
# Change NAKAMA_SERVER_KEY to a long random string in production.
NAKAMA_SERVER_KEY=defaultkey
